# ============================================================
# 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# Gemini API 配置
# 获取方式: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"

# 阿里云百炼 API 配置（可选）
# BAILIAN_BEIJING_URL="https://coding.dashscope.aliyuncs.com/v1"
# BAILIAN_SINGAPORE_URL="https://coding.dashscope.aliyuncs.com/v1"
# BAILIAN_US_URL="https://coding.dashscope.aliyuncs.com/v1"

# Gmail API 配置（可选）
# GMAIL_ADDRESS="your_email@gmail.com"
# GMAIL_APP_PASSWORD="your_app_password_here"

# GitHub Token（可选）
# GITHUB_TOKEN="ghp_your_token_here"

# ============================================================
# 安全提示：
# 1. .env 文件已在 .gitignore 中，不会被提交到 Git
# 2. 不要在代码中硬编码敏感信息
# 3. 定期更换 API Key
# 4. 不要分享 .env 文件
# ============================================================
